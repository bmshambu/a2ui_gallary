# ── DEV environment config ───────────────────────────────────────────────────
# Copy to .env.dev and fill in. Used when DEPLOYMENT_ENVIRONMENT=dev (default).

GCP_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_STAGING_BUCKET=gs://your-project-adk-staging-dev

AGENT_NAME=a2ui-gallery-agent-dev
AGENT_DISPLAY_NAME=A2UI Component Gallery (Dev)
AGENT_DESCRIPTION=Gallery agent demonstrating A2UI components (follow-up buttons, references modal, validated form, data table) in Gemini Enterprise. DEV deployment.
